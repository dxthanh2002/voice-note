    super.key,
    required this.text,
    required this.baseStyle,
    required this.contextStyle,
    this.onTick,
  });

  final String text;
  final TextStyle baseStyle;
  final TextStyle contextStyle;
  final VoidCallback? onTick;

  @override
  State<TypingText> createState() => _TypingTextState();
}

class _TypingTextState extends State<TypingText> {
  int _visibleLength = 0;
  Timer? _timer;

  @override
  void didUpdateWidget(TypingText oldWidget) {
    super.didUpdateWidget(oldWidget);
    if (oldWidget.text != widget.text) {
      _restart();
    }
  }

  @override
  void initState() {
    super.initState();
    _restart();
  }

  void _restart() {
    _timer?.cancel();
    _visibleLength = 0;
    if (widget.text.isEmpty) {
      return;
    }
    widget.onTick?.call();
    int tickCounter = 0;
    _timer = Timer.periodic(const Duration(milliseconds: 20), (timer) {
      if (!mounted) {
        timer.cancel();
        return;
      }
      if (_visibleLength >= widget.text.length) {
        timer.cancel();
        return;
      }
      setState(() => _visibleLength += 1);
      tickCounter += 1;
      if (tickCounter % 3 == 0) {
        widget.onTick?.call();
      }
    });
  }

  @override
  void dispose() {
    _timer?.cancel();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final visibleText = widget.text.substring(0, _visibleLength.clamp(0, widget.text.length));
    return RichText(
      text: TextSpan(
        children: buildStyledTextSpans(visibleText, widget.baseStyle, widget.contextStyle),
      ),
    );
  }
}

List<TextSpan> buildStyledTextSpans(String text, TextStyle baseStyle, TextStyle contextStyle) {
  if (text.isEmpty) {
    return [TextSpan(text: text, style: baseStyle)];
  }
  final regex = RegExp(r'\[[^\]]+\]');
  final spans = <TextSpan>[];
  int lastIndex = 0;
  for (final match in regex.allMatches(text)) {
    if (match.start > lastIndex) {
      spans.add(TextSpan(text: text.substring(lastIndex, match.start), style: baseStyle));
    }
    final segment = text.substring(match.start + 1, match.end - 1);
    spans.add(TextSpan(text: segment, style: contextStyle));
    lastIndex = match.end;
  }
  if (lastIndex < text.length) {
    spans.add(TextSpan(text: text.substring(lastIndex), style: baseStyle));
  }
  return spans;
}
