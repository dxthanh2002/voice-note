<file path="lib/screens/create_my_character_screen.dart">
import 'package:flutter/material.dart';
import 'package:image_picker/image_picker.dart';

import '../components/screen.dart';
import '../models/bot_creation.dart';
import '../navigation/app_routes.dart';
import '../services/repository.dart';
import '../theme/colors.dart';
import '../theme/typography.dart';
import '../utils/file.dart';

class CreateMyCharacterScreen extends StatefulWidget {
  const CreateMyCharacterScreen({super.key, required this.initialBot});

  final BotCreation initialBot;

  @override
  State<CreateMyCharacterScreen> createState() => _CreateMyCharacterScreenState();
}

class _CreateMyCharacterScreenState extends State<CreateMyCharacterScreen> {
  late String _name;
  late String _description;
  String _style = 'anime';
  String _gender = 'male';
  String _avatar = '';
  String _avatarStorage = '';

  @override
  void initState() {
    super.initState();
    final bot = widget.initialBot;
    _name = bot.name ?? '';
    _description = bot.description ?? '';
    _style = bot.style ?? 'anime';
    _gender = bot.gender ?? 'male';
    _avatar = bot.avatar ?? bot.photo ?? '';
    _avatarStorage = bot.photoStorage ?? '';
  }

  bool get _canNext => _name.trim().isNotEmpty && _description.trim().isNotEmpty && _avatar.isNotEmpty;

  Future<void> _pickAvatar() async {
    final picker = ImagePicker();
    final result = await picker.pickImage(source: ImageSource.gallery, imageQuality: 80);
    if (result == null) {
      return;
    }
    final uploadModel = await Repository.uploadFileName(nameFile: getFileName(result.path));
    final mimeType = getMimeType(result.path);
    await Repository.uploadToServer(
      uploadUrl: uploadModel.upload,
      filePath: result.path,
      mimeType: mimeType,
    );
    final storageUrl = uploadModel.fileStoreUrl ?? uploadModel.imageStorage ?? '';
    setState(() {
      _avatar = uploadModel.preview;
      _avatarStorage = storageUrl;
    });
  }

  Future<void> _generateAvatar() async {
    final response = await Repository.getImageBot(
      type: 'avatar',
      gennes: _gender,
      style: _style,
      description: _description,
    );
    setState(() {
      _avatar = response.image;
      _avatarStorage = response.imageStorage;
    });
  }

  void _next() {
    final nextBot = widget.initialBot.copyWith(
      name: _name,
      description: _description,
      style: _style,
      gender: _gender,
      avatar: _avatarStorage.isNotEmpty ? _avatarStorage : _avatar,
      photoStorage: _avatarStorage,
      photo: _avatar,
    );
    Navigator.of(context).pushNamed(AppRoutes.characterInfo, arguments: nextBot);
  }

  @override
  Widget build(BuildContext context) {
    final stylesList = [
      {'key': 'anime', 'label': 'Anime', 'image': 'assets/images/imv_style_anime.png'},
      {'key': 'normal', 'label': 'Normal', 'image': 'assets/images/imv_style_normal.png'},
      {'key': 'realistic', 'label': 'Realistic', 'image': 'assets/images/imv_style_realistic.png'},
    ];

    return Screen(
      child: SingleChildScrollView(
        padding: const EdgeInsets.all(20),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(
              widget.initialBot.isEdit == true ? 'Edit My Character' : 'Create My Character',
              style: const TextStyle(
                fontFamily: AppTypography.family,
                fontWeight: FontWeight.w700,
                fontSize: 18,
                color: AppColors.white,
              ),
            ),
            const SizedBox(height: 20),
            const Text('Name', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
            const SizedBox(height: 8),
            TextField(
              onChanged: (value) => setState(() => _name = value),
              style: const TextStyle(color: AppColors.white),
              decoration: const InputDecoration(
                filled: true,
                fillColor: Color(0xFF191919),
                hintText: 'Name',
                hintStyle: TextStyle(color: AppColors.gray7),
                border: OutlineInputBorder(borderSide: BorderSide.none),
              ),
            ),
            const SizedBox(height: 12),
            const Text('Description', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
            const SizedBox(height: 8),
            TextField(
              onChanged: (value) => setState(() => _description = value),
              maxLines: 4,
              style: const TextStyle(color: AppColors.white),
              decoration: const InputDecoration(
                filled: true,
                fillColor: Color(0xFF191919),
                hintText: 'Describe your character',
                hintStyle: TextStyle(color: AppColors.gray7),
                border: OutlineInputBorder(borderSide: BorderSide.none),
              ),
            ),
            const SizedBox(height: 12),
            const Text('Style', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
            const SizedBox(height: 8),
            Row(
              children: stylesList.map((item) {
                final key = item['key'] as String;
                final isActive = _style == key;
                return GestureDetector(
                  onTap: () => setState(() => _style = key),
                  child: Container(
                    margin: const EdgeInsets.only(right: 12),
                    child: Column(
                      children: [
                        Container(
                          width: 90,
                          height: 90,
                          decoration: BoxDecoration(
                            borderRadius: BorderRadius.circular(10),
                            border: Border.all(color: isActive ? AppColors.pinkText : AppColors.purple2),
                            image: DecorationImage(
                              image: AssetImage(item['image'] as String),
                              fit: BoxFit.cover,
                            ),
                          ),
                        ),
                        const SizedBox(height: 6),
                        Text(
                          item['label'] as String,
                          style: TextStyle(
                            fontFamily: AppTypography.family,
                            color: isActive ? AppColors.pinkText : AppColors.white,
                          ),
                        ),
                      ],
                    ),
                  ),
                );
              }).toList(),
            ),
            const SizedBox(height: 12),
            const Text('Gender', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
            const SizedBox(height: 8),
            Wrap(
              spacing: 12,
              children: ['male', 'female', 'nonbinary'].map((item) {
                final isActive = _gender == item;
                return ChoiceChip(
                  label: Text(item, style: const TextStyle(fontFamily: AppTypography.family)),
                  selected: isActive,
                  selectedColor: AppColors.bgGennes,
                  backgroundColor: AppColors.black2,
                  side: BorderSide(color: isActive ? AppColors.lineGennes : AppColors.purple2),
                  onSelected: (_) => setState(() => _gender = item),
                );
              }).toList(),
            ),
            const SizedBox(height: 12),
            const Text('Avatar', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
            const SizedBox(height: 8),
            Row(
              children: [
                Container(
                  width: 110,
                  height: 110,
                  decoration: BoxDecoration(
                    color: AppColors.blackGrey,
                    borderRadius: BorderRadius.circular(12),
                    image: _avatar.isNotEmpty ? DecorationImage(image: NetworkImage(_avatar), fit: BoxFit.cover) : null,
                  ),
                ),
                const SizedBox(width: 16),
                Column(
                  children: [
                    TextButton(
                      onPressed: _pickAvatar,
                      style: TextButton.styleFrom(
                        backgroundColor: AppColors.purple3,
                        padding: const EdgeInsets.symmetric(horizontal: 14, vertical: 8),
                      ),
                      child: const Text('Upload', style: TextStyle(color: AppColors.white)),
                    ),
                    const SizedBox(height: 8),
                    TextButton(
                      onPressed: _generateAvatar,
                      style: TextButton.styleFrom(
                        backgroundColor: AppColors.pink,
                        padding: const EdgeInsets.symmetric(horizontal: 14, vertical: 8),
                      ),
                      child: const Text('Generate', style: TextStyle(color: AppColors.white)),
                    ),
                  ],
                ),
              ],
            ),
            const SizedBox(height: 24),
            SizedBox(
              width: double.infinity,
              child: ElevatedButton(
                onPressed: _canNext ? _next : null,
                style: ElevatedButton.styleFrom(
                  backgroundColor: _canNext ? AppColors.blue3 : AppColors.bgBtnDisable,
                  shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
                  padding: const EdgeInsets.symmetric(vertical: 12),
                ),
                child: const Text('Next', style: TextStyle(color: AppColors.white)),
              ),
            ),
          ],
        ),
      ),
    );
  }
}
</file>

