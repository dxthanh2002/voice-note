import 'dart:async';

import 'package:flutter/material.dart';
import 'package:provider/provider.dart';

import '../components/screen.dart';
import '../contexts/app_context.dart';
import '../models/bots.dart';
import '../models/chat.dart';
import '../navigation/app_routes.dart';
import '../services/repository.dart';
import '../theme/colors.dart';
import '../theme/typography.dart';
import '../utils/device.dart';
import '../widgets/typing_text.dart';

class ConversationScreen extends StatefulWidget {
  const ConversationScreen({super.key, required this.bot});

  final BotItem? bot;

  @override
  State<ConversationScreen> createState() => _ConversationScreenState();
}

class _ConversationScreenState extends State<ConversationScreen> {
  final List<ChatMessage> _messages = [];
  final TextEditingController _inputController = TextEditingController();
  final ScrollController _scrollController = ScrollController();
  int _page = 0;
  bool _isEnd = false;
  String _threadId = '';

  @override
  void initState() {
    super.initState();
    _threadId = widget.bot?.threadId ?? '';
    _ensureThread();
    _checkPurchase();
    _scrollController.addListener(_onScroll);
  }

  @override
  void dispose() {
    _inputController.dispose();
    _scrollController.dispose();
    super.dispose();
  }

  Future<void> _ensureThread() async {
    if (_threadId.isNotEmpty || widget.bot?.id == null) {
      return;
    }
    try {
      final deviceId = await getDeviceId();
      final response = await Repository.createNewMessages(widget.bot!.id, deviceId);
      final thread = response['thread_id']?.toString();
      if (thread != null && mounted) {
        setState(() => _threadId = thread);
        await _fetchMessages();
      }
    } catch (_) {
      // Ignore.
    }
  }

  void _onScroll() {
    if (_scrollController.offset <= 50 && !_scrollController.position.outOfRange) {
      _fetchMessages();
    }
  }

  Future<void> _checkPurchase() async {
    try {
      final response = await Repository.checkPurchase();
      if (!mounted) {
        return;
      }
      context.read<AppState>().setIsPurchase(response.checkExpires);
    } catch (_) {
      if (!mounted) {
        return;
      }
      context.read<AppState>().setIsPurchase(false);
    }
  }

  Future<void> _fetchMessages() async {
    if (_isEnd || _threadId.isEmpty) {
      return;
    }
    try {
      final response = await Repository.readMessages(_threadId, _page);
      final incoming = response.messages ?? [];
      if (incoming.isNotEmpty) {
        final botName = widget.bot?.name ?? 'Bot';
        final normalized = incoming.map((message) {
          if (message.sender == 'char') {
            final content = message.content.replaceAll('{{char}}', botName);
            return message.copyWith(content: content, premium: context.read<AppState>().isPurchase);
          }
          return message;
        }).toList();
        setState(() {
          _messages.insertAll(0, _uniqueMessages(normalized));
          _page = response.index ?? _page + 1;
          if (incoming.length < 10) {
            _isEnd = true;
          }
        });
      }
    } catch (_) {
      // Ignore.
    }
  }

  List<ChatMessage> _uniqueMessages(List<ChatMessage> items) {
    final seen = <String>{};
    final result = <ChatMessage>[];
    for (final item in items) {
      final id = item.id ?? item.legacyId;
      if (id == null || !seen.contains(id)) {
        if (id != null) {
          seen.add(id);
        }
        result.add(item);
      }
    }
    return result;
  }

  Future<void> _sendMessage() async {
    final text = _inputController.text.trim();
    if (text.isEmpty) {
      return;
    }
    final userMessage = ChatMessage(
      sender: 'user',
      content: text,
      createdAt: DateTime.now().toIso8601String(),
    );
    setState(() {
      _messages.add(userMessage);
      _inputController.clear();
    });
    _scrollToEnd();

    final pendingId = 'pending-${DateTime.now().millisecondsSinceEpoch}';
    final pending = ChatMessage(
      id: pendingId,
      sender: 'char',
      content: '',
      createdAt: DateTime.now().toIso8601String(),
      avatar: widget.bot?.photo ?? '',
      isPingLoading: true,
      isTextEffect: true,
    );
    setState(() => _messages.add(pending));

    try {
      if (_threadId.isEmpty) {
        return;
      }
      final response = await Repository.createMessages(_threadId, text);
      final replyText = response.message.replaceAll('{{char}}', widget.bot?.name ?? 'Bot');
      setState(() {
        _messages.removeWhere((item) => item.id == pendingId);
        _messages.add(pending.copyWith(
          id: response.id,
          content: replyText,
          isPingLoading: false,
          isTextEffect: true,
        ));
      });
      _scrollToEnd();
    } catch (_) {
      setState(() => _messages.removeWhere((item) => item.id == pendingId));
    }
  }

  Future<void> _handleImage(ChatMessage message) async {
    final isPurchase = context.read<AppState>().isPurchase;
    if (message.image != null && message.image!.isNotEmpty) {
      if (isPurchase) {
        Navigator.of(context).pushNamed(AppRoutes.detailImage, arguments: message.image);
      }
      return;
    }
    try {
      final response = await Repository.getImage(idMessage: message.id ?? '', content: message.content);
      setState(() {
        final index = _messages.indexOf(message);
        if (index >= 0) {
          _messages[index] = message.copyWith(image: response.image, premium: isPurchase);
        }
      });
    } catch (_) {
      // Ignore.
    }
  }

  void _scrollToEnd() {
    Timer(const Duration(milliseconds: 50), () {
      if (_scrollController.hasClients) {
        _scrollController.animateTo(
          _scrollController.position.maxScrollExtent,
          duration: const Duration(milliseconds: 200),
          curve: Curves.easeOut,
        );
      }
    });
  }

  @override
  Widget build(BuildContext context) {
    final botName = widget.bot?.name ?? 'Bot';
    return Screen(
      child: Column(
        children: [
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
            child: Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                TextButton(
                  onPressed: () => Navigator.of(context).pop(),
                  child: const Text(
                    'Back',
                    style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white),
                  ),
                ),
                Text(
                  botName,
                  style: const TextStyle(
                    fontFamily: AppTypography.family,
                    fontWeight: FontWeight.w700,
                    fontSize: 16,
                    color: AppColors.white,
                  ),
                ),
                const SizedBox(width: 40),
              ],
            ),
          ),
          Expanded(
            child: ListView.builder(
              controller: _scrollController,
              padding: const EdgeInsets.symmetric(horizontal: 16),
              itemCount: _messages.length,
              itemBuilder: (context, index) {
                final message = _messages[index];
                final isUser = message.sender == 'user';
                return Container(
                  margin: const EdgeInsets.only(bottom: 12),
                  alignment: isUser ? Alignment.centerRight : Alignment.centerLeft,
                  child: Container(
                    padding: const EdgeInsets.all(12),
                    constraints: BoxConstraints(maxWidth: MediaQuery.of(context).size.width * 0.8),
                    decoration: BoxDecoration(
                      color: isUser ? AppColors.pink : AppColors.purple3,
                      borderRadius: BorderRadius.circular(16),
                    ),
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        if (message.isPingLoading == true)
                          const Text(
                            '...',
                            style: TextStyle(color: AppColors.white, fontFamily: AppTypography.family),
                          )
                        else if (message.isTextEffect == true)
                          TypingText(
                            text: message.content,
                            baseStyle: const TextStyle(color: AppColors.white, fontFamily: AppTypography.family),
                            contextStyle: const TextStyle(
                              color: AppColors.white,
                              fontFamily: AppTypography.family,
                              fontStyle: FontStyle.italic,
                            ),
                            onTick: _scrollToEnd,
                          )
                        else
                          RichText(
                            text: TextSpan(
                              children: buildStyledTextSpans(
                                message.content,
                                const TextStyle(color: AppColors.white, fontFamily: AppTypography.family),
                                const TextStyle(
                                  color: Colors.white70,
                                  fontFamily: AppTypography.family,
                                  fontStyle: FontStyle.italic,
                                ),
                              ),
                            ),
                          ),
                        if (message.image != null && message.image!.isNotEmpty)
                          GestureDetector(
                            onTap: () => _handleImage(message),
                            child: Column(
                              crossAxisAlignment: CrossAxisAlignment.start,
                              children: const [
                                SizedBox(height: 10),
                                _ImagePlaceholder(),
                              ],
                            ),
                          ),
                      ],
                    ),
                  ),
                );
              },
            ),
          ),
          Container(
            padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
            color: AppColors.black2,
            child: Row(
              children: [
                Expanded(
                  child: Container(
                    decoration: BoxDecoration(
                      color: const Color(0xFF191919),
                      borderRadius: BorderRadius.circular(16),
                    ),
                    child: TextField(
                      controller: _inputController,
                      style: const TextStyle(color: AppColors.white),
                      decoration: const InputDecoration(
                        hintText: 'Message',
                        hintStyle: TextStyle(color: AppColors.gray7),
                        border: InputBorder.none,
                        contentPadding: EdgeInsets.symmetric(horizontal: 12, vertical: 12),
                      ),
                      onChanged: (_) => setState(() {}),
                    ),
                  ),
                ),
                const SizedBox(width: 8),
                TextButton(
                  onPressed: _inputController.text.trim().isEmpty ? null : _sendMessage,
                  style: TextButton.styleFrom(
                    backgroundColor: AppColors.blue3,
                    padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 10),
                    shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
                  ),
                  child: const Text(
                    'Send',
                    style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white),
