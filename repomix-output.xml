class Repository {
  static Future<ProfileUser> login({required String deviceId, required String firebaseToken}) async {
    final response = await apiClient.post('account/login', data: {
      'device_id': deviceId,
      'firebase_token': firebaseToken,
    });
    return ProfileUser.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<BotsResponse> getListBots({
    required int index,
    String? keyword,
    List<BotTag>? tags,
  }) async {
    final response = await apiClient.post('bots/read/all', data: {
      'index': index,
      'kw': keyword,
      'tags': tags?.map((tag) => tag.toJson()).toList(),
    });
    return BotsResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<Map<String, dynamic>> createNewMessages(String agentId, String userId) async {
    final response = await apiClient.post(
      'thread/create/new',
      data: {
        'agent_id': agentId,
        'user_id': userId,
      },
      options: Options(contentType: Headers.formUrlEncodedContentType),
    );
    return response.data as Map<String, dynamic>;
  }

  static Future<CreateMessagesResponse> createMessages(String threadId, String content) async {
    final response = await apiClient.post(
      'thread/create/messages',
      data: {
        'thread_id': threadId,
        'content': content,
      },
      options: Options(contentType: Headers.formUrlEncodedContentType),
    );
    return CreateMessagesResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<ChatConversationResponse> readMessages(String threadId, int index) async {
    final response = await apiClient.post(
      'thread/read/messages',
      data: {
        'thread_id': threadId,
        'index': index,
      },
    );
    return ChatConversationResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<CategoryResponse> categoryBot() async {
    final response = await apiClient.post(
      'bots/read/filters',
      data: {'page': '0'},
      options: Options(contentType: Headers.formUrlEncodedContentType),
    );
    return CategoryResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<HistoryChatResponse> historyChat(int index) async {
    final response = await apiClient.post('thread/read/history', data: {'index': index});
    return HistoryChatResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<UploadFileResponse> uploadFileName({required String nameFile}) async {
    final response = await apiClient.post('account/getKeyUploadS3', data: {'name_file': nameFile});
    return UploadFileResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<Response> uploadToServer({
    required String uploadUrl,
    required String filePath,
    required String mimeType,
  }) async {
    final fileBytes = await File(filePath).readAsBytes();
    final client = Dio();
    return client.put(
      uploadUrl,
      data: Stream.fromIterable([fileBytes]),
      options: Options(
        headers: {
          'Content-Type': mimeType,
          'Content-Length': fileBytes.length,
        },
      ),
    );
  }

  static Future<dynamic> updateInfo({required String title, required String avatar, required String describe}) async {
    final response = await apiClient.post('account/update_title', data: {
      'title': title,
      'avatar': avatar,
      'describe': describe,
    });
    return response.data;
  }

  static Future<CheckPurchaseResponse> checkPurchase() async {
    final response = await apiClient.post('account/checkPurchase');
    return CheckPurchaseResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<GetImageResponse> getImage({required String idMessage, required String content}) async {
    final response = await apiClient.post('account/getImage', data: {
      'id_message': idMessage,
      'content': content,
    });
    return GetImageResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<GetImageResponse> getImageBot({
    required String type,
    required String gennes,
    required String style,
    required String description,
  }) async {
    final response = await apiClient.post('account/getImageBot', data: {
      'type': type,
      'gennes': gennes,
      'style': style,
      'description': description,
    });
    return GetImageResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<dynamic> verifyPurchase({
    required String type,
    required String productId,
    required String purchaseToken,
  }) async {
    final response = await apiClient.post('account/verifyPurchaseAndroid', data: {
      'type': type,
      'productId': productId,
      'purchaseToken': purchaseToken,
    });
    return response.data;
  }

  static Future<ImagesResponse> getImageOnBoard() async {
    final response = await apiClient.get('account/imageOnBroad');
    return ImagesResponse.fromJson(response.data as Map<String, dynamic>);
