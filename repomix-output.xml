<file path="lib/contexts/app_context.dart">
import 'dart:convert';

import 'package:flutter/foundation.dart';

import '../models/profile_user.dart';
import '../services/api_client.dart';
import '../services/storage.dart';

class AppStorageKeys {
  static const String token = 'auth_token';
  static const String profile = 'profile';
}

class AppState extends ChangeNotifier {
  String? _token;
  ProfileUser? _profile;
  bool _isPurchase = false;
  bool _booted = false;

  String? get token => _token;
  ProfileUser? get profile => _profile;
  bool get isPurchase => _isPurchase;
  bool get booted => _booted;

  Future<void> boot() async {
    if (_booted) {
      return;
    }
    final storedToken = await StorageService.get(AppStorageKeys.token);
    if (storedToken != null) {
      await setToken(storedToken);
    }
    final storedProfile = await StorageService.get(AppStorageKeys.profile);
    if (storedProfile != null) {
      try {
        final decoded = jsonDecode(storedProfile) as Map<String, dynamic>;
        _profile = ProfileUser.fromJson(decoded);
      } catch (_) {
        _profile = null;
      }
    }
    _booted = true;
    notifyListeners();
  }

  Future<void> setToken(String? value) async {
    _token = value;
    setApiToken(value);
    if (value != null && value.isNotEmpty) {
      await StorageService.set(AppStorageKeys.token, value);
    } else {
      await StorageService.remove(AppStorageKeys.token);
    }
    notifyListeners();
  }

  void setProfile(ProfileUser? value) {
    _profile = value;
    if (value != null) {
      StorageService.set(AppStorageKeys.profile, jsonEncode(value.toJson()));
    } else {
      StorageService.remove(AppStorageKeys.profile);
    }
    notifyListeners();
  }

  void setIsPurchase(bool value) {
    _isPurchase = value;
    notifyListeners();
  }
}
</file>

<file path="lib/main.dart">
import 'package:flutter/material.dart';
import 'package:provider/provider.dart';

import 'contexts/app_context.dart';
import 'navigation/app_navigator.dart';
import 'screens/loading_screen.dart';
import 'screens/main_tabs.dart';
import 'screens/start_screen.dart';
import 'services/app_bootstrap.dart';
import 'theme/app_theme.dart';

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  await AppBootstrap.init();
  runApp(const AiMateApp());
}

class AiMateApp extends StatelessWidget {
  const AiMateApp({super.key});

  @override
  Widget build(BuildContext context) {
    return ChangeNotifierProvider(
      create: (_) => AppState()..boot(),
      child: MaterialApp(
        title: 'AIMate',
        theme: buildAppTheme(),
        onGenerateRoute: buildRoute,
        home: const AppRoot(),
      ),
    );
  }
}

class AppRoot extends StatelessWidget {
  const AppRoot({super.key});

  @override
  Widget build(BuildContext context) {
    return Consumer<AppState>(
      builder: (context, state, _) {
        if (!state.booted) {
          return const LoadingScreen();
        }
        if (state.token == null || state.token!.isEmpty) {
          return const StartScreen();
        }
        return const MainTabs();
      },
    );
  }
}
