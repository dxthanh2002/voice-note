<file path="lib/screens/my_bot_screen.dart">
import 'package:flutter/material.dart';

import '../components/screen.dart';
import '../models/bot_creation.dart';
import '../models/bots.dart';
import '../navigation/app_routes.dart';
import '../services/repository.dart';
import '../theme/colors.dart';
import '../theme/typography.dart';
import '../utils/device.dart';

class MyBotScreen extends StatefulWidget {
  const MyBotScreen({super.key});

  @override
  State<MyBotScreen> createState() => _MyBotScreenState();
}

class _MyBotScreenState extends State<MyBotScreen> {
  List<BotCreation> _bots = [];
  int _page = 0;
  bool _isEnd = false;

  @override
  void initState() {
    super.initState();
    _loadBots(0, reset: true);
  }

  Future<void> _loadBots(int nextPage, {bool reset = false}) async {
    if (_isEnd && !reset) {
      return;
    }
    try {
      final response = await Repository.listBot(nextPage);
      final nextItems = response.data;
      setState(() {
        if (reset) {
          _bots = nextItems;
        } else {
          _bots.addAll(nextItems);
        }
        _page = response.index ?? nextPage + 1;
        if (nextItems.length < 10) {
          _isEnd = true;
        }
      });
    } catch (_) {
      setState(() => _isEnd = true);
    }
  }

  Future<void> _onChat(BotCreation bot) async {
    final deviceId = await getDeviceId();
    final response = await Repository.createNewMessages(bot.id ?? '', deviceId);
    final chatBot = BotItem(
      id: bot.id ?? '',
      name: bot.name ?? '',
      introduction: bot.description ?? '',
      photo: bot.photo ?? '',
      threadId: response['thread_id']?.toString(),
    );
    if (!mounted) {
      return;
    }
    Navigator.of(context).pushNamed(AppRoutes.conversation, arguments: chatBot);
  }

  @override
  Widget build(BuildContext context) {
    return Screen(
      child: Column(
        children: [
          const SizedBox(height: 16),
          const Text(
            'My Character',
            style: TextStyle(
              fontFamily: AppTypography.family,
              fontWeight: FontWeight.w600,
              fontSize: 16,
              color: AppColors.white,
            ),
          ),
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 24),
            child: ElevatedButton(
              onPressed: () => Navigator.of(context).pushNamed(AppRoutes.createCharacter, arguments: BotCreation()),
              style: ElevatedButton.styleFrom(
                backgroundColor: AppColors.pink,
                shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(24)),
                padding: const EdgeInsets.symmetric(vertical: 12),
              ),
              child: const Center(
                child: Text(
                  'Create new character',
                  style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white),
                ),
              ),
            ),
          ),
          Expanded(
            child: NotificationListener<ScrollNotification>(
              onNotification: (notification) {
                if (notification.metrics.pixels >= notification.metrics.maxScrollExtent * 0.6) {
                  _loadBots(_page);
                }
                return false;
              },
              child: ListView.builder(
                padding: const EdgeInsets.only(bottom: 120),
                itemCount: _bots.length,
                itemBuilder: (context, index) {
                  final bot = _bots[index];
                  return Container(
                    margin: const EdgeInsets.fromLTRB(20, 0, 20, 20),
                    padding: const EdgeInsets.all(16),
                    decoration: BoxDecoration(
                      borderRadius: BorderRadius.circular(20),
                      border: Border.all(color: AppColors.purple2),
                      color: AppColors.black2,
                    ),
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Row(
                          children: [
                            Container(
                              width: 80,
                              height: 80,
                              decoration: BoxDecoration(
                                color: AppColors.blackGrey,
                                borderRadius: BorderRadius.circular(12),
                                image: bot.photo != null && bot.photo!.isNotEmpty
                                    ? DecorationImage(image: NetworkImage(bot.photo!), fit: BoxFit.cover)
                                    : null,
                              ),
                            ),
                            const SizedBox(width: 16),
                            Expanded(
                              child: Column(
                                crossAxisAlignment: CrossAxisAlignment.start,
                                children: [
                                  Text(
                                    bot.name ?? '',
                                    style: const TextStyle(
                                      fontFamily: AppTypography.family,
                                      fontWeight: FontWeight.w700,
                                      color: AppColors.white,
                                    ),
                                  ),
                                  const SizedBox(height: 8),
                                  Text(
                                    bot.description ?? '',
                                    maxLines: 2,
                                    overflow: TextOverflow.ellipsis,
                                    style: const TextStyle(
                                      fontFamily: AppTypography.family,
                                      fontSize: 12,
                                      color: AppColors.gray7,
                                    ),
                                  ),
                                ],
                              ),
                            ),
                          ],
                        ),
                        const SizedBox(height: 16),
                        const Text(
                          'Review',
                          style: TextStyle(
                            fontFamily: AppTypography.family,
                            fontWeight: FontWeight.w700,
                            color: AppColors.white,
                          ),
                        ),
                        const SizedBox(height: 8),
                        Text(
                          bot.scenario ?? 'No description yet.',
                          style: const TextStyle(
                            fontFamily: AppTypography.family,
                            fontSize: 12,
                            color: AppColors.gray7,
                          ),
                        ),
                        const SizedBox(height: 16),
                        Row(
                          children: [
                            Expanded(
                              child: TextButton(
                                onPressed: () => _onChat(bot),
                                style: TextButton.styleFrom(
                                  backgroundColor: AppColors.purple3,
                                  shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
                                  padding: const EdgeInsets.symmetric(vertical: 10),
                                ),
                                child: const Text(
                                  'Chat',
                                  style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white),
                                ),
                              ),
                            ),
                            const SizedBox(width: 12),
                            Expanded(
                              child: TextButton(
                                onPressed: () => Navigator.of(context).pushNamed(
                                  AppRoutes.createCharacter,
                                  arguments: bot.copyWith(isEdit: true),
                                ),
                                style: TextButton.styleFrom(
                                  backgroundColor: AppColors.purple3,
                                  shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
                                  padding: const EdgeInsets.symmetric(vertical: 10),
                                ),
                                child: const Text(
                                  'Edit',
                                  style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white),
                                ),
                              ),
                            ),
                          ],
                        ),
                      ],
                    ),
                  );
                },
              ),
            ),
          ),
        ],
      ),
    );
  }
}
