class CharacterInformationScreen extends StatefulWidget {
  const CharacterInformationScreen({super.key, required this.initialBot});

  final BotCreation initialBot;

  @override
  State<CharacterInformationScreen> createState() => _CharacterInformationScreenState();
}

class _CharacterInformationScreenState extends State<CharacterInformationScreen> {
  late String _story;
  late String _personality;
  late String _firstMessage;
  bool _isPublic = false;
  String _firstImage = '';
  String _firstImageStorage = '';
  List<CategoryItem> _tags = [];

  @override
  void initState() {
    super.initState();
    final bot = widget.initialBot;
    _story = bot.scenario ?? '';
    _personality = bot.personality ?? '';
    _firstMessage = bot.firstMessage ?? '';
    _isPublic = bot.isPublic ?? false;
    _firstImage = bot.firstImage ?? '';
    _firstImageStorage = bot.firstImageStorage ?? '';
    _loadTags();
  }

  Future<void> _loadTags() async {
    final response = await Repository.categoryBot();
    final mapped = response.data.map((tag) {
      final selected = widget.initialBot.tags?.any((item) => item.id == tag.id) ?? false;
      return tag.copyWith(isSelected: selected);
    }).toList();
    setState(() => _tags = mapped);
  }

  List<Map<String, String>> get _selectedTags {
    return _tags
        .where((tag) => tag.isSelected)
        .map((tag) => {'id': tag.id, 'name': tag.name})
        .toList();
  }

  bool get _canCreate {
    return _story.trim().isNotEmpty &&
        _personality.trim().isNotEmpty &&
        _firstMessage.trim().isNotEmpty &&
        _firstImageStorage.isNotEmpty &&
        _selectedTags.isNotEmpty;
  }

  Future<void> _pickFirstImage() async {
    final picker = ImagePicker();
    final result = await picker.pickImage(source: ImageSource.gallery, imageQuality: 80);
    if (result == null) {
      return;
    }
    final uploadModel = await Repository.uploadFileName(nameFile: getFileName(result.path));
    final mimeType = getMimeType(result.path);
    await Repository.uploadToServer(
      uploadUrl: uploadModel.upload,
      filePath: result.path,
      mimeType: mimeType,
    );
    final storageUrl = uploadModel.fileStoreUrl ?? uploadModel.imageStorage ?? '';
    setState(() {
      _firstImage = uploadModel.preview;
      _firstImageStorage = storageUrl;
    });
  }

  Future<void> _generateImage() async {
    final response = await Repository.getImageBot(
      type: 'image',
      gennes: widget.initialBot.gender ?? 'male',
      style: widget.initialBot.style ?? 'anime',
      description: _story,
    );
    setState(() {
      _firstImage = response.image;
      _firstImageStorage = response.imageStorage;
    });
  }

  Future<void> _submit() async {
    final payload = widget.initialBot.copyWith(
      scenario: _story,
      personality: _personality,
      firstMessage: _firstMessage,
      isPublic: _isPublic,
      gennes: widget.initialBot.gender,
      firstImage: _firstImage,
      firstImageStorage: _firstImageStorage,
      tags: _tags.where((tag) => tag.isSelected).map((tag) => BotTag(id: tag.id, name: tag.name)).toList(),
    );

    if (widget.initialBot.isEdit == true) {
      await Repository.updateBot(payload);
    } else {
      await Repository.createBot(payload);
    }

    if (!mounted) {
      return;
    }
    Navigator.of(context).pop();
  }

  @override
  Widget build(BuildContext context) {
    return Screen(
      child: SingleChildScrollView(
        padding: const EdgeInsets.all(20),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text(
              'Character Information',
              style: TextStyle(
                fontFamily: AppTypography.family,
                fontWeight: FontWeight.w700,
                fontSize: 18,
                color: AppColors.white,
              ),
            ),
            const SizedBox(height: 16),
            const Text('Story', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
            const SizedBox(height: 8),
            TextField(
              onChanged: (value) => setState(() => _story = value),
              maxLines: 4,
              style: const TextStyle(color: AppColors.white),
              decoration: const InputDecoration(
                filled: true,
                fillColor: Color(0xFF191919),
                hintText: 'Story',
                hintStyle: TextStyle(color: AppColors.gray7),
                border: OutlineInputBorder(borderSide: BorderSide.none),
              ),
            ),
            const SizedBox(height: 12),
            const Text('Personality', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
            const SizedBox(height: 8),
            TextField(
              onChanged: (value) => setState(() => _personality = value),
              style: const TextStyle(color: AppColors.white),
              decoration: const InputDecoration(
                filled: true,
                fillColor: Color(0xFF191919),
                hintText: 'Personality',
                hintStyle: TextStyle(color: AppColors.gray7),
                border: OutlineInputBorder(borderSide: BorderSide.none),
              ),
            ),
            const SizedBox(height: 12),
            const Text('First message', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
            const SizedBox(height: 8),
            TextField(
              onChanged: (value) => setState(() => _firstMessage = value),
              style: const TextStyle(color: AppColors.white),
              decoration: const InputDecoration(
                filled: true,
                fillColor: Color(0xFF191919),
                hintText: 'First message',
                hintStyle: TextStyle(color: AppColors.gray7),
                border: OutlineInputBorder(borderSide: BorderSide.none),
              ),
            ),
            const SizedBox(height: 12),
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                const Text('Public', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
                Switch(value: _isPublic, onChanged: (value) => setState(() => _isPublic = value)),
              ],
            ),
            const SizedBox(height: 12),
            const Text('Tags', style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white)),
            const SizedBox(height: 8),
            Wrap(
              spacing: 10,
              runSpacing: 10,
              children: _tags.map((tag) {
                return ChoiceChip(
                  label: Text(tag.name, style: const TextStyle(fontFamily: AppTypography.family)),
                  selected: tag.isSelected,
                  selectedColor: AppColors.pinkText,
                  backgroundColor: AppColors.purple3,
