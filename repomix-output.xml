  static Future<ChatConversationResponse> readMessages(String threadId, int index) async {
    final response = await apiClient.post(
      'thread/read/messages',
      data: {
        'thread_id': threadId,
        'index': index,
      },
    );
    return ChatConversationResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<CategoryResponse> categoryBot() async {
    final response = await apiClient.post(
      'bots/read/filters',
      data: {'page': '0'},
      options: Options(contentType: Headers.formUrlEncodedContentType),
    );
    return CategoryResponse.fromJson(response.data as Map<String, dynamic>);
  }

