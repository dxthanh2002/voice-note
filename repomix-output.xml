  }

  static Future<InfoPurchaseResponse> getInfoPurchase() async {
    final response = await apiClient.get('account/info_purchase');
    return InfoPurchaseResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<dynamic> createBot(BotCreation payload) async {
    final response = await apiClient.post('account/createBot', data: payload.toJson());
    return response.data;
  }

  static Future<dynamic> updateBot(BotCreation payload) async {
    final response = await apiClient.post('account/saveBot', data: payload.toJson());
    return response.data;
  }

  static Future<dynamic> removeBot(String id) async {
