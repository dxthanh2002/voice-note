class Repository {
  static Future<ProfileUser> login({required String deviceId, required String firebaseToken}) async {
    final response = await apiClient.post('account/login', data: {
      'device_id': deviceId,
      'firebase_token': firebaseToken,
    });
    return ProfileUser.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<BotsResponse> getListBots({
    required int index,
    String? keyword,
    List<BotTag>? tags,
  }) async {
    final response = await apiClient.post('bots/read/all', data: {
      'index': index,
      'kw': keyword,
      'tags': tags?.map((tag) => tag.toJson()).toList(),
    });
    return BotsResponse.fromJson(response.data as Map<String, dynamic>);
  }

  static Future<Map<String, dynamic>> createNewMessages(String agentId, String userId) async {
    final response = await apiClient.post(
      'thread/create/new',
      data: {
        'agent_id': agentId,
        'user_id': userId,
      },
      options: Options(contentType: Headers.formUrlEncodedContentType),
    );
    return response.data as Map<String, dynamic>;
  }

  static Future<CreateMessagesResponse> createMessages(String threadId, String content) async {
    final response = await apiClient.post(
      'thread/create/messages',
      data: {
        'thread_id': threadId,
        'content': content,
      },
      options: Options(contentType: Headers.formUrlEncodedContentType),
    );
    return CreateMessagesResponse.fromJson(response.data as Map<String, dynamic>);
