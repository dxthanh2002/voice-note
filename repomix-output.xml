    final shouldDelete = await showDialog<bool>(
      context: context,
      builder: (ctx) => AlertDialog(
        backgroundColor: AppColors.cardDark,
        title: const Text('Xóa bản ghi?'),
        content: Text(
          'Bản ghi "${recording.title}" sẽ bị xóa vĩnh viễn.',
