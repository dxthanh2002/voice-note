import 'package:flutter/material.dart';

import '../models/bot_creation.dart';
import '../models/bots.dart';
import '../navigation/app_routes.dart';
import '../screens/character_information_screen.dart';
import '../screens/conversation_screen.dart';
import '../screens/create_my_character_screen.dart';
import '../screens/detail_image_screen.dart';
import '../screens/main_tabs.dart';
import '../screens/notification_screen.dart';
import '../screens/onboarding_screen.dart';
import '../screens/purchase_screen.dart';
import '../screens/start_screen.dart';

Route<dynamic> buildRoute(RouteSettings settings) {
  switch (settings.name) {
    case AppRoutes.start:
      return MaterialPageRoute(builder: (_) => const StartScreen());
    case AppRoutes.onboarding:
      return MaterialPageRoute(builder: (_) => const OnboardingScreen());
    case AppRoutes.main:
      return MaterialPageRoute(builder: (_) => const MainTabs());
    case AppRoutes.conversation:
      final bot = settings.arguments as BotItem?;
      return MaterialPageRoute(builder: (_) => ConversationScreen(bot: bot));
    case AppRoutes.detailImage:
      final imageUrl = settings.arguments as String? ?? '';
      return MaterialPageRoute(builder: (_) => DetailImageScreen(imageUrl: imageUrl));
    case AppRoutes.createCharacter:
      final bot = settings.arguments as BotCreation? ?? BotCreation();
      return MaterialPageRoute(builder: (_) => CreateMyCharacterScreen(initialBot: bot));
    case AppRoutes.characterInfo:
      final bot = settings.arguments as BotCreation? ?? BotCreation();
      return MaterialPageRoute(builder: (_) => CharacterInformationScreen(initialBot: bot));
    case AppRoutes.purchase:
      return MaterialPageRoute(builder: (_) => const PurchaseScreen());
    case AppRoutes.notification:
      return MaterialPageRoute(builder: (_) => const NotificationScreen());
    default:
      return MaterialPageRoute(builder: (_) => const StartScreen());
  }
}
