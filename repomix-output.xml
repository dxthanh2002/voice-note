  static Future<BotListResponse> listBot(int index) async {
    final response = await apiClient.post('account/list_bot', data: {'index': index});
    return BotListResponse.fromJson(response.data as Map<String, dynamic>);
  }
}

String getMimeType(String path) {
  final lower = path.toLowerCase();
  if (lower.endsWith('.jpg') || lower.endsWith('.jpeg')) {
    return 'image/jpeg';
  }
  if (lower.endsWith('.png')) {
    return 'image/png';
  }
  if (lower.endsWith('.webp')) {
    return 'image/webp';
  }
  return 'application/octet-stream';
}

String resolveS3Url(String path) {
  if (path.startsWith('http')) {
    return path;
  }
  return '$s3BaseUrl$path';
}
