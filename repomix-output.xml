          Container(
            margin: const EdgeInsets.symmetric(horizontal: 8),
            padding: const EdgeInsets.all(20),
            decoration: BoxDecoration(
              color: AppColors.purpleBlack,
              borderRadius: BorderRadius.circular(16),
            ),
            child: appState.isPurchase
                ? const Text(
