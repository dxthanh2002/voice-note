class _StartScreenState extends State<StartScreen> {
  @override
  void initState() {
    super.initState();
    _login();
  }

  Future<void> _login() async {
    try {
      final deviceId = await getDeviceId();
      final firebaseToken = await getPushToken();
      final response = await Repository.login(deviceId: deviceId, firebaseToken: firebaseToken);
      if (!mounted) {
        return;
      }
      final appState = context.read<AppState>();
      if (response.accessToken != null && response.accessToken!.isNotEmpty) {
        await appState.setToken(response.accessToken);
      }
      appState.setProfile(response);
    } catch (_) {
      // Ignore and continue to main.
    }
    if (!mounted) {
      return;
    }
    Navigator.of(context).pushNamedAndRemoveUntil(AppRoutes.main, (route) => false);
  }

  @override
