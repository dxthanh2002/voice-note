import '../services/repository.dart';
import '../theme/colors.dart';
import '../theme/typography.dart';

class ChatScreen extends StatefulWidget {
  const ChatScreen({super.key});

  @override
  State<ChatScreen> createState() => _ChatScreenState();
}

class _ChatScreenState extends State<ChatScreen> {
  final List<HistoryChatThread> _threads = [];
  int _page = 0;
  bool _isEnd = false;
  bool _loading = false;

  @override
  void initState() {
    super.initState();
    _loadThreads(0, reset: true);
  }

  Future<void> _loadThreads(int nextPage, {bool reset = false}) async {
    if (_loading || (_isEnd && !reset)) {
      return;
    }
    setState(() => _loading = true);
    try {
      final response = await Repository.historyChat(nextPage);
      final nextItems = response.threads;
      setState(() {
        if (reset) {
          _threads
            ..clear()
            ..addAll(nextItems);
        } else {
          _threads.addAll(nextItems);
        }
        _page = response.index ?? nextPage + 1;
        if (nextItems.length < 10) {
          _isEnd = true;
        }
      });
    } catch (_) {
      setState(() => _isEnd = true);
    } finally {
      setState(() => _loading = false);
    }
  }

  void _openConversation(HistoryChatThread thread) {
    final bot = BotItem(
      id: thread.agent.id,
      name: thread.agent.name,
      introduction: thread.agent.introduction,
      photo: thread.agent.photo,
      threadId: thread.id,
    );
    Navigator.of(context).pushNamed(AppRoutes.conversation, arguments: bot);
  }

  @override
  Widget build(BuildContext context) {
    return Screen(
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Padding(
            padding: EdgeInsets.fromLTRB(24, 16, 24, 12),
            child: Text(
              'Chat',
              style: TextStyle(
                fontFamily: AppTypography.family,
                fontWeight: FontWeight.w700,
                fontSize: 18,
                color: AppColors.white,
              ),
            ),
          ),
          Expanded(
            child: NotificationListener<ScrollNotification>(
              onNotification: (notification) {
                if (notification.metrics.pixels >= notification.metrics.maxScrollExtent * 0.7) {
                  _loadThreads(_page);
                }
                return false;
              },
              child: ListView.builder(
                padding: const EdgeInsets.fromLTRB(16, 0, 16, 100),
                itemCount: _threads.length,
                itemBuilder: (context, index) {
                  final thread = _threads[index];
                  return InkWell(
                    onTap: () => _openConversation(thread),
                    child: Container(
                      margin: const EdgeInsets.only(bottom: 12),
                      padding: const EdgeInsets.all(12),
                      decoration: BoxDecoration(
                        color: const Color(0xFF191919),
                        borderRadius: BorderRadius.circular(12),
                      ),
                      child: Row(
                        children: [
                          Container(
                            width: 48,
                            height: 48,
                            decoration: BoxDecoration(
                              color: AppColors.blackGrey,
                              shape: BoxShape.circle,
                              image: thread.agent.photo.isNotEmpty
                                  ? DecorationImage(
                                      image: NetworkImage(thread.agent.photo),
                                      fit: BoxFit.cover,
                                    )
                                  : null,
                            ),
                          ),
                          const SizedBox(width: 12),
                          Expanded(
                            child: Column(
                              crossAxisAlignment: CrossAxisAlignment.start,
                              children: [
                                Text(
                                  thread.agent.name,
                                  style: const TextStyle(
                                    fontFamily: AppTypography.family,
                                    fontWeight: FontWeight.w600,
                                    color: AppColors.white,
                                  ),
                                ),
                                const SizedBox(height: 4),
                                Text(
                                  thread.latestMessage.content,
                                  maxLines: 2,
                                  overflow: TextOverflow.ellipsis,
                                  style: const TextStyle(
                                    fontFamily: AppTypography.family,
                                    color: AppColors.gray7,
                                    fontSize: 12,
                                  ),
                                ),
                              ],
                            ),
                          ),
                        ],
                      ),
                    ),
                  );
                },
              ),
            ),
          ),
        ],
      ),
    );
  }
}
