<file path="lib/screens/explore_screen.dart">
import 'package:flutter/material.dart';
import 'package:provider/provider.dart';

import '../components/screen.dart';
import '../contexts/app_context.dart';
import '../models/bots.dart';
import '../models/category.dart';
import '../navigation/app_routes.dart';
import '../services/repository.dart';
import '../theme/colors.dart';
import '../theme/typography.dart';
import '../utils/device.dart';

class ExploreScreen extends StatefulWidget {
  const ExploreScreen({super.key});

  @override
  State<ExploreScreen> createState() => _ExploreScreenState();
}

class _ExploreScreenState extends State<ExploreScreen> {
  final TextEditingController _searchController = TextEditingController();
  List<CategoryItem> _topics = [];
  List<BotItem> _bots = [];
  int _page = 0;
  bool _isEnd = false;
  bool _loading = false;

  @override
  void initState() {
    super.initState();
    _loadTopics();
    _loadBots(0, reset: true);
    _checkPurchase();
    _searchController.addListener(_onSearchChanged);
  }

  @override
  void dispose() {
    _searchController.removeListener(_onSearchChanged);
    _searchController.dispose();
    super.dispose();
  }

  void _onSearchChanged() {
    _isEnd = false;
    _loadBots(0, reset: true);
  }

  Future<void> _checkPurchase() async {
    try {
      final response = await Repository.checkPurchase();
      if (!mounted) {
        return;
      }
      context.read<AppState>().setIsPurchase(response.checkExpires);
    } catch (_) {
      if (!mounted) {
        return;
      }
      context.read<AppState>().setIsPurchase(false);
    }
  }

  Future<void> _loadTopics() async {
    try {
      final response = await Repository.categoryBot();
      setState(() => _topics = response.data);
    } catch (_) {
      setState(() => _topics = []);
    }
  }

  List<BotTag> get _selectedTags {
    return _topics.where((item) => item.isSelected).map((item) => BotTag(id: item.id, name: item.name)).toList();
  }

  Future<void> _loadBots(int nextPage, {bool reset = false}) async {
    if (_loading || (_isEnd && !reset)) {
      return;
    }
    setState(() => _loading = true);
    try {
      final response = await Repository.getListBots(
        index: nextPage,
        keyword: _searchController.text,
        tags: _selectedTags,
      );
      final nextItems = response.data;
      setState(() {
        if (reset) {
          _bots = nextItems;
        } else {
          _bots.addAll(nextItems);
        }
        _page = response.index ?? nextPage + 1;
        if (nextItems.length < 10) {
          _isEnd = true;
        }
      });
    } finally {
      if (mounted) {
        setState(() => _loading = false);
      }
    }
  }

  void _toggleTopic(CategoryItem topic) {
    setState(() {
      _topics = _topics
          .map((item) => item.id == topic.id ? item.copyWith(isSelected: !item.isSelected) : item)
          .toList();
    });
    _isEnd = false;
    _loadBots(0, reset: true);
  }

  Future<void> _startChat(BotItem bot) async {
    try {
      final deviceId = await getDeviceId();
      final response = await Repository.createNewMessages(bot.id, deviceId);
      final threadId = response['thread_id']?.toString();
      final nextBot = BotItem(
        id: bot.id,
        name: bot.name,
        introduction: bot.introduction,
        photo: bot.photo,
        threadId: threadId,
      );
      if (!mounted) {
        return;
      }
      Navigator.of(context).pushNamed(AppRoutes.conversation, arguments: nextBot);
    } catch (_) {
      // Ignore.
    }
  }

  Future<void> _showBotModal(BotItem bot) async {
    await showModalBottomSheet(
      context: context,
      backgroundColor: AppColors.black2,
      shape: const RoundedRectangleBorder(
        borderRadius: BorderRadius.vertical(top: Radius.circular(20)),
      ),
      builder: (context) {
        return Padding(
          padding: const EdgeInsets.all(20),
          child: Column(
            mainAxisSize: MainAxisSize.min,
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Text(
                bot.name,
                style: const TextStyle(
                  fontFamily: AppTypography.family,
                  fontWeight: FontWeight.w700,
                  fontSize: 20,
                  color: AppColors.white,
                ),
              ),
              const SizedBox(height: 8),
              Text(
                bot.introduction,
                style: const TextStyle(
                  fontFamily: AppTypography.family,
                  color: AppColors.gray7,
                ),
              ),
              const SizedBox(height: 16),
              Row(
                mainAxisAlignment: MainAxisAlignment.end,
                children: [
                  TextButton(
                    onPressed: () => Navigator.of(context).pop(),
                    style: TextButton.styleFrom(
                      backgroundColor: AppColors.purple3,
                      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 10),
                    ),
                    child: const Text(
                      'Cancel',
                      style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white),
                    ),
                  ),
                  const SizedBox(width: 10),
                  TextButton(
                    onPressed: () {
                      Navigator.of(context).pop();
                      _startChat(bot);
                    },
                    style: TextButton.styleFrom(
                      backgroundColor: AppColors.pink,
                      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 10),
                    ),
                    child: const Text(
                      'Chat',
                      style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white),
                    ),
                  ),
                ],
              ),
            ],
          ),
        );
      },
    );
  }

  @override
  Widget build(BuildContext context) {
    final appState = context.watch<AppState>();
    final profileName = appState.profile?.data.name ?? 'Name Anonymous';

    return Screen(
      child: Column(
        children: [
          Padding(
            padding: const EdgeInsets.fromLTRB(24, 12, 24, 0),
            child: Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                Text(
                  profileName,
                  style: const TextStyle(
                    fontFamily: AppTypography.family,
                    fontSize: 18,
                    color: AppColors.white,
                  ),
                ),
                if (!appState.isPurchase)
                  TextButton(
                    onPressed: () => Navigator.of(context).pushNamed(AppRoutes.purchase),
                    style: TextButton.styleFrom(
                      backgroundColor: AppColors.red2,
                      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 6),
                      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(14)),
                    ),
                    child: const Text(
                      'Get Pro+',
                      style: TextStyle(fontFamily: AppTypography.family, color: AppColors.white),
                    ),
                  ),
              ],
            ),
          ),
          Container(
            margin: const EdgeInsets.fromLTRB(24, 16, 24, 0),
            padding: const EdgeInsets.symmetric(horizontal: 16),
            decoration: BoxDecoration(
              color: const Color(0xFF191919),
              borderRadius: BorderRadius.circular(16),
            ),
            child: TextField(
              controller: _searchController,
              style: const TextStyle(color: AppColors.white),
              decoration: const InputDecoration(
                hintText: 'Search',
                hintStyle: TextStyle(color: AppColors.gray7),
                border: InputBorder.none,
              ),
            ),
          ),
          SizedBox(
            height: 120,
            child: ListView.builder(
              padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 16),
              scrollDirection: Axis.horizontal,
              itemCount: _topics.length,
              itemBuilder: (context, index) {
                final topic = _topics[index];
                return GestureDetector(
                  onTap: () => _toggleTopic(topic),
                  child: Container(
                    width: 72,
                    margin: const EdgeInsets.only(right: 14),
                    child: Column(
                      children: [
                        Container(
                          width: 56,
                          height: 56,
                          decoration: BoxDecoration(
                            color: AppColors.blackGrey,
                            shape: BoxShape.circle,
                            border: Border.all(
                              color: topic.isSelected ? AppColors.white : Colors.transparent,
                              width: 2,
                            ),
                            image: topic.photo != null && topic.photo!.isNotEmpty
                                ? DecorationImage(image: NetworkImage(topic.photo!), fit: BoxFit.cover)
                                : null,
                          ),
                        ),
                        const SizedBox(height: 8),
                        Text(
                          topic.name,
                          textAlign: TextAlign.center,
                          style: const TextStyle(
                            fontFamily: AppTypography.family,
                            color: AppColors.white,
                            fontSize: 12,
                          ),
                        ),
                      ],
                    ),
                  ),
                );
              },
            ),
          ),
          Expanded(
            child: NotificationListener<ScrollNotification>(
              onNotification: (notification) {
                if (notification.metrics.pixels >= notification.metrics.maxScrollExtent * 0.6) {
                  _loadBots(_page);
                }
                return false;
              },
              child: GridView.builder(
                padding: const EdgeInsets.fromLTRB(12, 0, 12, 120),
                gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
                  crossAxisCount: 2,
                  childAspectRatio: 0.7,
                  crossAxisSpacing: 12,
                  mainAxisSpacing: 12,
                ),
                itemCount: _bots.length,
                itemBuilder: (context, index) {
                  final bot = _bots[index];
                  return GestureDetector(
                    onTap: () => _showBotModal(bot),
                    child: Container(
                      padding: const EdgeInsets.all(10),
                      decoration: BoxDecoration(
                        color: const Color(0xFF191919),
                        borderRadius: BorderRadius.circular(12),
                      ),
                      child: Column(
                        crossAxisAlignment: CrossAxisAlignment.start,
                        children: [
                          Container(
                            height: 120,
                            decoration: BoxDecoration(
                              color: AppColors.blackGrey,
                              borderRadius: BorderRadius.circular(8),
                              image: bot.photo.isNotEmpty
                                  ? DecorationImage(image: NetworkImage(bot.photo), fit: BoxFit.cover)
                                  : null,
                            ),
                          ),
                          const SizedBox(height: 10),
                          Text(
                            bot.name,
                            style: const TextStyle(
                              fontFamily: AppTypography.family,
                              fontWeight: FontWeight.w600,
                              fontSize: 16,
                              color: AppColors.white,
                            ),
                          ),
                          const SizedBox(height: 6),
                          Text(
                            bot.introduction,
                            maxLines: 3,
                            overflow: TextOverflow.ellipsis,
